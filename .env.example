# ── Contracts (fill after running: npm run deploy) ──────────────────
DEPLOYER_PRIVATE_KEY=your_deployer_wallet_private_key_here

# ── Agent ────────────────────────────────────────────────────────────
AGENT_PRIVATE_KEY=your_agent_wallet_private_key_here
DONATION_VAULT_ADDRESS=paste_from_deploy_output
BADGE_ADDRESS=paste_from_deploy_output

# ── Frontend (Vite reads VITE_ prefixed vars) ────────────────────────
VITE_DONATION_VAULT_ADDRESS=paste_from_deploy_output
VITE_BADGE_ADDRESS=paste_from_deploy_output

# ─────────────────────────────────────────────────────────────────────
# HOW TO GET PRIVATE KEYS:
# 1. Open MetaMask → click account → Account details → Export private key
# 2. Use DIFFERENT wallets for deployer and agent
# 3. NEVER commit this file to GitHub — it's in .gitignore
# ─────────────────────────────────────────────────────────────────────
